# KITmate server 環境変数のサンプル。
# 本番では `cp .env.example .env` して値を埋める (.env はコミットしない)。

# 休講取得 (KIT ポータル直スクレイプ用、必須)。未設定だと休講取得はエラーになる。
KIT_USER_ID=b4xxxxxx
KIT_PASSWORD=your-password
# KIT_VPN_HOST=vpns.cis.kit.ac.jp   # 既定値。通常は変更不要

# web-push の VAPID subject (mailto: または URL)
# VAPID_SUBJECT=mailto:you@example.com

# 休講 push 通知 (1分毎のウォッチャ) を止めたいとき
# PUSH_DISABLED=1
